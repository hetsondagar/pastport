# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/pastport
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/pastport

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# Cloudinary Configuration (for media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (for notifications)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ML service integration
# In production, set this to your deployed ML service URL (no trailing slash),
# for example: https://pastport-ml-service.onrender.com
ML_SERVICE_URL=http://localhost:8000
# Increase for Render cold starts/model warmup if needed
ML_SERVICE_TIMEOUT_MS=90000
# Retry transient startup/network failures
ML_SERVICE_RETRIES=1

# Groq LLM integration — model IDs: https://console.groq.com/docs/models
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=openai/gpt-oss-120b
# Optional comma-separated fallback order (Mixtral / llama3-* IDs are ignored as legacy)
GROQ_MODEL_CANDIDATES=openai/gpt-oss-120b,openai/gpt-oss-20b,qwen/qwen3-32b,llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=12000
# Set to 1 to log Groq key/model diagnostics once on startup usage (recommended on Render)
GROQ_DIAGNOSTIC_LOGS=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
